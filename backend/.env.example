PORT=4000
NODE_ENV=development

# Comma-separated list (or leave empty for any origin during development).
CORS_ORIGIN=

# Firebase project configuration
FIREBASE_PROJECT_ID=your-firebase-project-id

# Used by POST /login (Firebase Auth REST API).
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Provide credentials via exactly one of the following:
#
# 1) Firebase service account JSON (as a single-line JSON string).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
#    You can also reference a file to avoid embedding secrets in .env:
# FIREBASE_SERVICE_ACCOUNT_JSON=@./serviceAccountKey.json
#
# 2) Firebase service account file path:
# FIREBASE_SERVICE_ACCOUNT_FILE=./serviceAccountKey.json
#
# 3) Or use ADC:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

